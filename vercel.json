{
  "version": 2,
  "regions": ["icn1"],
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "server.js",  "use": "@vercel/node", "config": { "maxDuration": 300 } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/",         "dest": "/index.html" }
  ]
}
